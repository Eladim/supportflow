{
  "name": "supportflow",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "argon2",
      "esbuild",
      "@scarf/scarf",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "pnpm run --parallel dev:api dev:web",
    "dev:api": "pnpm --filter @supportflow/api dev",
    "dev:web": "pnpm --filter @supportflow/web dev",
    "build": "pnpm -r run build",
    "db:generate": "pnpm --filter @supportflow/api db:generate",
    "db:migrate": "pnpm --filter @supportflow/api db:migrate",
    "db:push": "pnpm --filter @supportflow/api db:push",
    "db:seed": "pnpm --filter @supportflow/api db:seed"
  },
  "engines": {
    "node": ">=20"
  }
}
